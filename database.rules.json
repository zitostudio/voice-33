{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "rooms": {
      ".read": "auth != null",
      "$room_id": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || !data.exists() || data.child('createdBy').val() === auth.uid)",
        "activeHosts": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid"
          }
        },
        "participants": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid"
          }
        }
      }
    }
  }
}
